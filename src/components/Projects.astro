---
const projects = [
  {
    title: "Fiber Optic Network Manager (OSP)",
    description: "Full-stack GIS platform for fiber optic network management. Interactive map visualization with MapLibre GL and Mapbox GL Draw. Clean/Hexagonal Architecture backend with dual database (SQL Server + PostgreSQL). Azure AD authentication, DuckDB analytics, and Docker deployment.",
    image: "../images/ftth.png",
    tags: ["React", "TypeScript", "Node.js", "SQL Server", "PostgreSQL", "MapLibre", "Redux Toolkit", "Docker", "Azure AD", "Clean Architecture"],
    demoUrl: "#",
    repoUrl: "#"
  },
  {
    title: "Territorial Analytics Platform (ATU)",
    description: "Big data territorial analysis platform with 3D visualization using Deck.gl. FastAPI backend with Elasticsearch for large-scale geospatial search. Data processing with Pandas, GeoPandas, H3 hexagonal indexing, and PyArrow/Parquet formats.",
    image: "../images/atu.png",
    tags: ["React", "Next.js", "Python", "FastAPI",  "Deck.gl", "Redux Toolkit", "Docker", "H3", "TypeScript"],
    demoUrl: "#",
    repoUrl: "#"
  },
  {
    title: "Jockey Commercial Map (MapaJP)",
    description: "Microservices architecture with horizontally-scaled GeoServer cluster (master-slave) using ActiveMQ and Nginx load balancer. Kong API Gateway for service routing. Redis caching layer with K6 and Locust load testing.",
    image: "../images/jockey.png",
    tags: ["React", "GeoServer", "Docker", "NGINX", "Kong", "Redis", "TypeScript", "Leaflet", "Node.js", "PostgreSQL"],
    demoUrl: "https://vimeo.com/1061571858",
    repoUrl: "#"
  },
  {
    title: "Censo Predial Platform",
    description: "Census data visualization and management system with React, Redux, MapLibre GL and Deck.gl. Backend with Node.js/Express, Sequelize and PostgreSQL. File processing: shapefiles, Excel, ZIP and XML.",
    image: "../images/censo.png",
    tags: ["React", "MapLibre", "Deck.gl", "TypeScript", "Docker", "Python", "Node.js", "PostgreSQL", "GeoServer"],
    demoUrl: "https://vimeo.com/1069754132",
    repoUrl: "#"
  },
  {
    title: "Map Layer Styler",
    description: "Specialized tool for customizing and styling map layers with GeoServer integration. MapLibre and Mapbox for advanced cartographic style rendering. Dynamic color picker and real-time style preview.",
    image: "../images/layer-style.png",
    tags: ["React", "GeoServer", "TypeScript", "Redux Toolkit", "Mapbox", "MapLibre", "Python"],
    demoUrl: "https://vimeo.com/1028033387?share=copy",
    repoUrl: "https://custom-style-layer-maplibre-component-ten.vercel.app"
  },
  {
    title: "Geocoder V2",
    description: "High-performance geocoding service built with FastAPI. Redis caching layer with hiredis for sub-millisecond lookups. Fuzzy search using edit distance algorithms. Production deployment with Gunicorn.",
    image: "../images/geocoder.png",
    tags: ["Python", "FastAPI", "Redis", "Docker", "REST API", "Elasticsearch"],
    demoUrl: "#",
    repoUrl: "#"
  },
  {
    title: "Predictive Model Dashboard",
    description: "Machine learning dashboard with Scikit-learn and Prophet for time series forecasting. Hyperparameter optimization with Optuna. Interactive Chart.js visualizations on React frontend.",
    image: "../images/predictive.png",
    tags: ["React", "Python", "TypeScript", "Node.js"],
    demoUrl: "#",
    repoUrl: "#"
  },
  {
    title: "Market B2B",
    description: "B2B marketplace built with modern GraphQL architecture. Apollo Client/Server for efficient data management and commercial transactions between companies.",
    image: "../images/MDR.png",
    tags: ["React", "GraphQL", "PostgreSQL", "Node.js", "JavaScript"],
    demoUrl: "https://vimeo.com/manage/videos/876953448",
    repoUrl: "https://market-residuos.vercel.app"
  },
  {
    title: "Videogames Platform",
    description: "Web platform for videogames with PostgreSQL database for content management, interactive React interface and global state management with Redux.",
    image: "../images/Videogames.png",
    tags: ["React", "PostgreSQL", "Node.js", "JavaScript", "Express", "Redux"],
    demoUrl: "https://vimeo.com/876415669?share=copy",
    repoUrl: "#"
  }
];

const categories = ["All", "React", "Python", "TypeScript", "Node.js", "Docker", "GeoServer", "FastAPI"];
---

<section id="projects" class="py-20 bg-gray-50 dark:bg-gray-800 transition-colors duration-300">
  <div class="container mx-auto px-4">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-4">My Projects</h2>
    <p class="text-center text-gray-600 dark:text-gray-300 mb-12 max-w-xl mx-auto">
      Here are some of my recent projects that showcase my skills and expertise in web development.
    </p>
    
    <div class="flex justify-center flex-wrap gap-4 mb-12">
      {categories.map((category, index) => (
        <button 
          class={`px-4 py-2 rounded-lg transition-colors duration-300 ${index === 0 ? 'bg-primary-600 text-white' : 'bg-white dark:bg-gray-700 hover:bg-primary-600/10'}`}
          data-category={category}
        >
          {category}
        </button>
      ))}
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="projects-grid">
      {projects.map(project => (
        <div class="project-card bg-white dark:bg-gray-900 rounded-lg overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 animate-slide-up group" data-tags={JSON.stringify(project.tags)}>
          <div class="relative overflow-hidden h-48">
            <img 
              src={project.image} 
              alt={project.title} 
              class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-500"
            />

            <div class="absolute inset-0 bg-black/90 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center p-6">
              <div class="text-center transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
                <p class="text-white text-sm leading-relaxed">{project.description}</p>
              </div>
            </div>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-semibold mb-4">{project.title}</h3>
            <div class="flex flex-wrap gap-2 mb-6">
              {project.tags.map(tag => (
                <span class="px-2 py-1 bg-gray-100 dark:bg-gray-800 text-sm rounded-md">{tag}</span>
              ))}
            </div>
            <div class="flex gap-4">
              <a 
                href={project.demoUrl} 
                target="_blank" 
                rel="noopener noreferrer" 
                class="px-4 py-2 bg-primary-600 hover:bg-primary-700 text-white rounded-lg transition-colors duration-300 text-sm"
              >
                Live Demo
              </a>
              {project.repoUrl !== '#' && 
                <a 
                  href={project.repoUrl} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class="px-4 py-2 border border-primary-600 text-primary-600 dark:text-primary-400 hover:bg-primary-600/10 rounded-lg transition-colors duration-300 text-sm"
                >
                  Source Code
                </a>
              }
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const filterButtons = document.querySelectorAll('[data-category]');
    const projectCards = document.querySelectorAll('.project-card');
    
    // Filter projects on category click
    filterButtons.forEach(button => {
      button.addEventListener('click', () => {
        // Remove active class from all buttons
        filterButtons.forEach(btn => {
          btn.classList.remove('bg-primary-600', 'text-white');
          btn.classList.add('bg-white', 'dark:bg-gray-700', 'hover:bg-primary-600/10');
        });
        
        // Add active class to clicked button
        button.classList.add('bg-primary-600', 'text-white');
        button.classList.remove('bg-white', 'dark:bg-gray-700', 'hover:bg-primary-600/10');
        
        const category = button.getAttribute('data-category');
        
        // Filter projects
        projectCards.forEach(card => {
          const tagsAttribute = card.getAttribute('data-tags');
          const tags = JSON.parse(tagsAttribute);
          
          if (category === 'All' || tags.includes(category)) {
            card.style.display = 'block';
          } else {
            card.style.display = 'none';
          }
        });
      });
    });
  });
</script>